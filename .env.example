# ── Auth Service ──────────────────────────────────────────────────────────────
AUTH_PORT=3001
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── EMR Service ───────────────────────────────────────────────────────────────
EMR_PORT=3002

# ── CRM Service ───────────────────────────────────────────────────────────────
CRM_PORT=3003

# ── Admin Service ─────────────────────────────────────────────────────────────
ADMIN_PORT=3004

# ── Databases (set per-service by Railway; below are local Docker defaults) ──
AUTH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auth_db
EMR_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emr_db
CRM_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_db
ADMIN_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/admin_db

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Internal service auth (shared secret for service-to-service calls) ────────
INTERNAL_SERVICE_TOKEN=change-me-internal-secret

# ── Cross-service URLs (Docker Compose defaults; Railway uses private network) ─
EMR_SERVICE_URL=http://emr-service:3002
CRM_SERVICE_URL=http://crm-service:3003
ADMIN_SERVICE_URL=http://admin-service:3004

# ── CORS (comma-separated list of allowed frontend origins) ──────────────────
# Leave unset to use the hardcoded per-service default.
# On Railway, set to your frontend service URL, e.g.:
# CORS_ORIGIN=https://emr-frontend-production.up.railway.app
CORS_ORIGIN=

# ── Frontend nginx upstream URLs (Railway overrides; Docker uses defaults) ────
# Set on each frontend service in Railway to point at the backend private URLs.
# AUTH_SERVICE_URL=https://auth-service.railway.internal:3001
# BACKEND_SERVICE_URL=https://emr-service.railway.internal:3002
